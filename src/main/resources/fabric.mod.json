{
	"schemaVersion": 1,
	"id": "blockframe",
	"version": "${version}",
	"name": "BlockFrame",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/blockframe/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"xela.blockframe.BlockFrame"
		],
		"client": [
			"xela.blockframe.client.BlockFrameClient"
		],
		"fabric-datagen": [
			"xela.blockframe.client.BlockFrameDataGenerator"
		]
	},
	"mixins": [
		"blockframe.mixins.json",
		{
			"config": "blockframe.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}